<?xml version="1.0"?>
<ruleset name="Unique Query Loop Extension">
	<description>Coding standards for the Unique Query Loop Extension plugin.</description>

	<file>unique-query-loop-extension.php</file>
	<file>src</file>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="ps"/>

	<rule ref="WordPress">
		<!-- PSR-4 autoloading: file names mirror class names, not core's class-*.php scheme. -->
		<exclude name="WordPress.Files.FileName"/>
	</rule>

	<config name="minimum_wp_version" value="6.7"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="unique-query-loop-extension"/>
			</property>
		</properties>
	</rule>
</ruleset>
