# Itens excluídos do pacote de distribuição (ZIP / WordPress.org).
# Os arquivos PHP em src/ SÃO necessários (autoload). Apenas o JS-fonte é excluído,
# pois o runtime usa o bundle compilado em build/.
.github/
.git/
.gitignore
.gitattributes
.distignore
node_modules/
vendor/
scripts/
package.json
package-lock.json
npm-install.log
composer.json
composer.lock
docs/
src/index.js
*.md
*.zip
!readme.txt
languages/.gitkeep
